{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Reading Assistant Pro",
  "version": "0.1.0",
  "identifier": "com.readingassistant.pro",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "cmd /c exit 0",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Reading Assistant Pro",
        "width": 1080,
        "height": 760,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 880,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
